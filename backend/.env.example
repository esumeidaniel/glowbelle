NODE_ENV=development
PORT=5002
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/glowbelle
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
RATE_LIMIT_MAX=200
UPLOAD_DIR=uploads
VERIFICATION_UPLOAD_DIR=verification-uploads

# Business/admin notifications
ADMIN_NOTIFY_EMAIL=admin@example.com
SEED_ADMIN_NAME="GlowBelle Admin"
SEED_ADMIN_EMAIL=admin@glowbelle.com
SEED_ADMIN_PHONE=+2348001000000
SEED_ADMIN_PASSWORD=replace_with_a_private_admin_password
EMAIL_FROM="GlowBelle <no-reply@example.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=replace_with_smtp_app_password

# Pay at Salon launch mode. Keep card payments disabled.
ENABLE_CARD_PAYMENTS=false
PLATFORM_FEE_PERCENT=0

# Google login
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
