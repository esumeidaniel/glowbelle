{
  "name": "glowbelle-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Node.js, Express and MongoDB backend for GlowBelle salon booking platform.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/data/seed.js",
    "test": "node --test",
    "check": "node --check src/server.js",
    "check:email": "node src/scripts/checkEmail.js",
    "admin:password": "node src/scripts/setAdminPassword.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
